generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Sector {
  id        Int        @id @default(autoincrement())
  name      String
  divisions Division[]

  @@map("sectors")
}

model Division {
  id             Int                   @id @default(autoincrement())
  sectorId       Int                   @map("sector_id")
  name           String
  sector         Sector                @relation(fields: [sectorId], references: [id])
  profiles       Profile[]
  zoneStatistics ZoneStatisticsCache[]

  @@map("divisions")
}

model Specialty {
  id                  Int                   @id @default(autoincrement())
  code                String                @unique
  name                String
  branchCode          String                @map("branch_code")
  branchName          String                @map("branch_name")
  educationalCategory String                @map("educational_category")
  isPrimary           Boolean               @map("is_primary")
  isSecondary         Boolean               @map("is_secondary")
  profiles            Profile[]
  zoneStatistics      ZoneStatisticsCache[]

  @@map("specialties")
}

model Region {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  postingZones PostingZone[]

  @@map("regions")
}

model PostingZone {
  id              Int                   @id @default(autoincrement())
  regionId        Int                   @map("region_id")
  name            String
  region          Region                @relation(fields: [regionId], references: [id])
  currentProfiles Profile[]
  targetRequests  TargetZone[]
  originRequests  TransferRequest[]     @relation("OriginZone")
  zoneStatistics  ZoneStatisticsCache[]

  @@map("posting_zones")
}

model User {
  id            Int             @id @default(autoincrement())
  email         String          @unique
  passwordHash  String?         @map("password_hash")
  fullName      String?         @map("full_name")
  createdAt     DateTime        @default(now()) @map("created_at")
  emailVerified DateTime?       @map("email_verified")
  image         String?
  banReason     String?         @map("ban_reason")
  bannedAt      DateTime?       @map("banned_at")
  role          Role            @default(USER)
  status        UserStatus      @default(ACTIVE)
  avatarColor   String?         @map("avatar_color")
  accounts      Account[]
  auditLogs     AdminAuditLog[] @relation("AdminLogs")
  receivedLogs  AdminAuditLog[] @relation("TargetUserLogs")
  profile       Profile?
  sessions      Session[]

  @@map("users")
}

model AdminAuditLog {
  id           Int      @id @default(autoincrement())
  adminId      Int      @map("admin_id")
  targetUserId Int?     @map("target_user_id")
  action       String
  details      Json?
  createdAt    DateTime @default(now()) @map("created_at")
  admin        User     @relation("AdminLogs", fields: [adminId], references: [id])
  targetUser   User?    @relation("TargetUserLogs", fields: [targetUserId], references: [id])

  @@map("admin_audit_logs")
}

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int     @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique @map("session_token")
  userId       Int      @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Profile {
  id               Int               @id @default(autoincrement())
  userId           Int               @unique @map("user_id")
  specialtyId      Int               @map("specialty_id")
  divisionId       Int               @map("division_id")
  currentZoneId    Int               @map("current_zone_id")
  hireDate         DateTime          @default(dbgenerated("'2020-01-01 00:00:00'::timestamp without time zone")) @map("hire_date")
  serviceDays      Int               @default(10) @map("service_days")
  serviceMonths    Int               @default(10) @map("service_months")
  serviceYears     Int               @default(10) @map("service_years")
  messages         Message[]
  notifications    Notification[]
  currentZone      PostingZone       @relation(fields: [currentZoneId], references: [id])
  division         Division          @relation(fields: [divisionId], references: [id])
  specialty        Specialty         @relation(fields: [specialtyId], references: [id])
  user             User              @relation(fields: [userId], references: [id])
  transferRequests TransferRequest[]

  @@map("profiles")
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
  @@map("password_reset_tokens")
}

model TransferRequest {
  id                  Int                @id @default(autoincrement())
  profileId           Int                @map("profile_id")
  status              RequestStatus      @default(active)
  createdAt           DateTime           @default(now()) @map("created_at")
  completedAt         DateTime?          @map("completed_at")
  originZoneId        Int                @map("origin_zone_id")
  matchParticipations MatchParticipant[]
  targetZones         TargetZone[]
  originZone          PostingZone        @relation("OriginZone", fields: [originZoneId], references: [id])
  profile             Profile            @relation(fields: [profileId], references: [id])

  @@map("transfer_requests")
}

model TargetZone {
  id            Int             @id @default(autoincrement())
  requestId     Int             @map("request_id")
  zoneId        Int             @map("zone_id")
  priorityOrder Int             @map("priority_order")
  request       TransferRequest @relation(fields: [requestId], references: [id])
  zone          PostingZone     @relation(fields: [zoneId], references: [id])

  @@unique([requestId, zoneId])
  @@map("target_zones")
}

model Match {
  id            Int                @id @default(autoincrement())
  type          String
  status        String             @default("active")
  createdAt     DateTime           @default(now()) @map("created_at")
  completedAt   DateTime?          @map("completed_at")
  participants  MatchParticipant[]
  messages      Message[]
  notifications Notification[]

  @@map("matches")
}

model MatchParticipant {
  id        Int             @id @default(autoincrement())
  matchId   Int             @map("match_id")
  requestId Int             @map("request_id")
  match     Match           @relation(fields: [matchId], references: [id])
  request   TransferRequest @relation(fields: [requestId], references: [id])

  @@map("match_participants")
}

model Message {
  id              Int      @id @default(autoincrement())
  matchId         Int      @map("match_id")
  senderProfileId Int      @map("sender_profile_id")
  content         String
  createdAt       DateTime @default(now()) @map("created_at")
  match           Match    @relation(fields: [matchId], references: [id])
  senderProfile   Profile  @relation(fields: [senderProfileId], references: [id])

  @@map("messages")
}

model Notification {
  id        Int      @id @default(autoincrement())
  profileId Int      @map("profile_id")
  type      String
  matchId   Int      @map("match_id")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  match     Match    @relation(fields: [matchId], references: [id])
  profile   Profile  @relation(fields: [profileId], references: [id])

  @@map("notifications")
}

model ZoneStatisticsCache {
  id               Int         @id @default(autoincrement())
  zoneId           Int         @map("zone_id")
  specialtyId      Int         @map("specialty_id")
  divisionId       Int         @map("division_id")
  avgPoints        Float       @map("avg_points")
  lastCutOffPoints Float       @map("last_cut_off_points")
  demandCount      Int         @map("demand_count")
  supplyCount      Int         @map("supply_count")
  division         Division    @relation(fields: [divisionId], references: [id])
  specialty        Specialty   @relation(fields: [specialtyId], references: [id])
  zone             PostingZone @relation(fields: [zoneId], references: [id])

  @@map("zone_statistics_cache")
}

model TransferStatistics {
  id                        Int    @id @default(autoincrement())
  region                    String
  division                  String
  specialty                 String
  successCount              Int    @map("success_count")
  successCountDiff          Int    @map("success_count_diff")
  successCountHistory       Json   @map("success_count_history")
  baseScore                 Float? @map("base_score")
  baseScoreDiff             Float? @map("base_score_diff")
  baseScoreHistory          Json   @map("base_score_history")
  avgScore                  Float? @map("avg_score")
  avgScoreDiff              Float? @map("avg_score_diff")
  avgScoreHistory           Json   @map("avg_score_history")
  avgScoreApplicants        Float? @map("avg_score_applicants")
  avgScoreAppDiff           Float? @map("avg_score_app_diff")
  avgScoreAppHistory        Json   @map("avg_score_app_history")
  leavingCount              Int    @map("leaving_count")
  leavingCountDiff          Int    @map("leaving_count_diff")
  leavingCountHistory       Json   @map("leaving_count_history")
  targeting1stCount         Int    @map("targeting_1st_count")
  targeting1stCountDiff     Int    @map("targeting_1st_count_diff")
  targeting1stCountHistory  Json   @map("targeting_1st_count_history")
  inflowOriginsJson         Json   @map("inflow_origins_json")
  outflowTargetsJson        Json   @map("outflow_targets_json")
  difficultyCategory        String @map("difficulty_category")
  difficultyCategoryHistory Json   @map("difficulty_category_history")
  difficultyCategoryTrend   String @map("difficulty_category_trend")
  popularity                Float? @map("popularity")
  popularityHistory         Json?  @map("popularity_history")

  @@map("transfer_statistics")
}

model SpecialtyAnalytics {
  id                            Int    @id @default(autoincrement())
  specialty                     String
  division                      String
  successCount                  Int    @map("success_count")
  successCountHistory           Json   @map("success_count_history")
  successCountDiff              Int    @map("success_count_diff")
  baseScore                     Float? @map("base_score")
  baseScoreHistory              Json   @map("base_score_history")
  baseScoreDiff                 Float? @map("base_score_diff")
  avgScore                      Float? @map("avg_score")
  avgScoreHistory               Json   @map("avg_score_history")
  avgScoreDiff                  Float? @map("avg_score_diff")
  top5DestinationRegions        Json   @map("top_5_destination_regions")
  top5CompetitiveRegions        Json   @map("top_5_competitive_regions")
  nationalPointsRange           Float? @map("national_points_range")
  nationalPointsRangeHistory    Json   @map("national_points_range_history")
  nationalPointsRangeDiff       Float? @map("national_points_range_diff")
  specialCategoryRate           Float? @map("special_category_rate")
  specialCategoryRateHistory    Json   @map("special_category_rate_history")
  specialCategoryRateDiff       Float? @map("special_category_rate_diff")
  activeRegionsRate             Float? @map("active_regions_rate")
  activeRegionsRateHistory      Json   @map("active_regions_rate_history")
  activeRegionsRateDiff         Float? @map("active_regions_rate_diff")
  leavingCount                  Int    @map("leaving_count")
  leavingCountHistory           Json   @map("leaving_count_history")
  leavingCountDiff              Int    @map("leaving_count_diff")
  top5Targeting1st              Json   @map("top_5_targeting_1st")
  avgScoreApplicants            Float? @map("avg_score_applicants")
  avgScoreApplicantsHistory     Json   @map("avg_score_applicants_history")
  avgScoreApplicantsDiff        Float? @map("avg_score_applicants_diff")
  averagePreferenceCount        Float? @map("average_preference_count")
  averagePreferenceCountHistory Json   @map("average_preference_count_history")
  averagePreferenceCountDiff    Float? @map("average_preference_count_diff")
  pointsEntranceGap             Float? @map("points_entrance_gap")
  pointsEntranceGapHistory      Json   @map("points_entrance_gap_history")
  pointsEntranceGapDiff         Float? @map("points_entrance_gap_diff")
  oddsOfTransfer                Float? @map("odds_of_transfer")
  oddsOfTransferHistory         Json   @map("odds_of_transfer_history")
  oddsOfTransferDiff            Float? @map("odds_of_transfer_diff")
  waitingListAbsolute           Int    @map("waiting_list_absolute")
  waitingListAbsoluteHistory    Json   @map("waiting_list_absolute_history")
  waitingListAbsoluteDiff       Int    @map("waiting_list_absolute_diff")

  @@unique([specialty, division])
  @@map("specialty_analytics")
}

enum DivisionType {
  Primary
  Secondary
}

enum RequestStatus {
  active
  matched
  paused
  inactive
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
  SUSPENDED
}
